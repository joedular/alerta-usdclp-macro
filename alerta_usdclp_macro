def fetch_intraday_usdclp() -> Tuple[pd.DataFrame, Dict[str, Any]]:
    last_err = None
    tries = [
        ("1m", "1d"),
        ("5m", "1d"),
        ("15m", "5d"),
        ("30m", "5d"),
        ("60m", "10d"),
    ]

    for tk in USDCLP_CANDIDATES:
        for interval, period in tries:
            try:
                df = yf.download(
                    tk, period=period, interval=interval,
                    progress=False, auto_adjust=True, threads=True
                )
                if df is None or df.empty:
                    continue
                df = _flatten_yf_columns(df)
                if {"Open", "Close"}.issubset(df.columns):
                    return df, {"source": "intraday", "ticker": tk, "interval": interval, "period": period}
            except Exception as e:
                last_err = e

    for tk in USDCLP_CANDIDATES:
        try:
            df = yf.download(
                tk, period="10d", interval="1d",
                progress=False, auto_adjust=True, threads=True
            )
            if df is None or df.empty:
                continue
            df = _flatten_yf_columns(df)
            if {"Open", "Close"}.issubset(df.columns):
                return df, {"source": "daily_fallback", "ticker": tk, "interval": "1d", "period": "10d"}
        except Exception as e:
            last_err = e

    raise RuntimeError(f"No data para USDCLP (intradía ni diario). Last error: {last_err}")


