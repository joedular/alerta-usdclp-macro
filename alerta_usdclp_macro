            else:
                if np.isfinite(med):
                    print(f"{WEEKDAY_NAMES[wd]}: mediana={med:.2f} CLP (mean={mean:.2f} CLP, n={cnt}){tag2}")
                else:
                    print(f"{WEEKDAY_NAMES[wd]}: n/a (n={cnt})")

        print(f"Sugerencia: corre la app preferentemente el día {green(seas['best_day_name'])} entre 11:00–13:00 (heurística).")
    else:
        print(f"n/a: {seas.get('reason')}")
    print()

    print(bold("ML (probabilidad simple)"))
    if np.isfinite(prob_up_5d):
        print(f"Probabilidad de SUBIR en 5 días: {prob_up_5d:.2f}")
    else:
        print("Probabilidad de SUBIR en 5 días: n/a")
    print(ml_dbg)
    print()

    print(bold("Decisión"))
    print(f"Semáforo: {light}   |   Score: {score}/100")
    print(f"Razón: {rationale}")
    print()
    print(amount_str)
