def compute_macro_components(daily: pd.DataFrame) -> pd.DataFrame:
    out = pd.DataFrame(index=daily.index)

    out["dxy_ret_5d"] = daily["DXY"].pct_change(MACRO_RET_DAYS)
    out["us10y_ret_5d"] = daily["US10Y"].pct_change(MACRO_RET_DAYS)
    out["copper_ret_5d"] = daily["COPPER"].pct_change(MACRO_RET_DAYS)

    out["dxy_z"] = zscore(out["dxy_ret_5d"], MACRO_Z_WINDOW).fillna(0)
    out["us10y_z"] = zscore(out["us10y_ret_5d"], MACRO_Z_WINDOW).fillna(0)
    out["copper_z"] = zscore(out["copper_ret_5d"], MACRO_Z_WINDOW).fillna(0)

    out["usd_pressure"] = out["dxy_z"] + out["us10y_z"] - out["copper_z"]
    return out


