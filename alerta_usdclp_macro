def is_good_liquidity_time(now_local: datetime) -> bool:
    wd = now_local.weekday()
    hr = now_local.hour
    return (wd in BEST_DAYS) and (BEST_HOURS[0] <= hr <= BEST_HOURS[1])

def is_market_ok_time(now_local: datetime) -> bool:
    wd = now_local.weekday()
    hr = now_local.hour
    if wd in (5, 6):
        return False
    return MARKET_OK_HOURS[0] <= hr < MARKET_OK_HOURS[1]

def liquidity_hint(now_local: datetime) -> str:
    wd = now_local.weekday()
    hr = now_local.hour
    if is_good_liquidity_time(now_local):
        return "✅ Horario/Día recomendado (alta liquidez)."
    if wd in (5, 6):
        return "⚠️ Fin de semana: spread suele ser peor."
    if wd == 0 and hr < 11:
        return "⚠️ Lunes temprano: suele haber más ruido/spread."
    if wd == 4 and hr >= 15:
        return "⚠️ Viernes tarde: suele empeorar el spread."
    if hr < MARKET_OK_HOURS[0] or hr >= MARKET_OK_HOURS[1]:
        return "⚠️ Fuera de horario de mercado: spread suele ser peor."
    return "ℹ️ Horario intermedio: aceptable, pero no óptimo."

def zscore(s: pd.Series, window: int) -> pd.Series:
    mu = s.rolling(window=window, min_periods=max(10, window // 3)).mean()
    sd = s.rolling(window=window, min_periods=max(10, window // 3)).std()
    z = (s - mu) / sd
    return z.replace([np.inf, -np.inf], np.nan)

def learn_best_hours_usdclp(now_local: datetime) -> Dict[str, Any]:
    df = fetch_intraday_recent(TICKERS["USDCLP"], LEARN_HOURS_PERIOD, LEARN_HOURS_INTERVAL)
    if df.empty or len(df) < LEARN_HOURS_MIN_BARS:
        return {"ok": False, "reason": f"datos intradía insuficientes (barras={len(df)})."}

    df = _to_tz_chile_index(df)
    if df.empty:
        return {"ok": False, "reason": "no se pudo normalizar zona horaria en intradía."}

    d = df[["Close"]].copy()
    d["ret"] = d["Close"].pct_change().replace([np.inf, -np.inf], np.nan)
    d = d.dropna()
    if d.empty or len(d) < LEARN_HOURS_MIN_BARS // 2:
        return {"ok": False, "reason": "retornos intradía insuficientes tras limpieza."}

    d["weekday"] = d.index.weekday
    d["hour"] = d.index.hour

    d = d[(d["weekday"] <= 4) & (d["hour"] >= MARKET_OK_HOURS[0]) & (d["hour"] < MARKET_OK_HOURS[1])]
    if d.empty:
        return {"ok": False, "reason": "sin datos intradía dentro de horario de mercado."}

    g = d.groupby(["weekday", "hour"])["ret"].agg(
        abs_mean=lambda x: float(np.nanmean(np.abs(x))),
        mean=lambda x: float(np.nanmean(x)),
        count="count",
    ).reset_index()

    g = g[g["count"] >= 6]
    if g.empty:
        return {"ok": False, "reason": "muy pocas muestras por bloque horario."}

    g["score"] = g["abs_mean"] + 0.2 * np.maximum(g["mean"], 0.0)
    g = g.sort_values("score", ascending=True)

    top = []
    for _, row in g.head(LEARN_HOURS_TOPK).iterrows():
        top.append((int(row["weekday"]), int(row["hour"]), float(row["score"]), int(row["count"])))

    blocks = [f"{WEEKDAY_NAMES[wd]} {hr:02d}:00–{hr:02d}:59 (n={cnt})" for wd, hr, _, cnt in top]
    sug = " | ".join(blocks)

    best_wd, best_hr, _, _ = top[0]
    return {
        "ok": True,
        "top": top,
        "best_weekday": best_wd,
        "best_hour": best_hr,
        "suggestion_text": (
            f"Aprendido (intradía {LEARN_HOURS_PERIOD}/{LEARN_HOURS_INTERVAL}): "
            f"mejor bloque ≈ {WEEKDAY_NAMES[best_wd]} {best_hr:02d}:00–{best_hr:02d}:59. Top: {sug}"
        ),
    }

def market_hours_gate_message(now_local: datetime, learned: Optional[Dict[str, Any]]) -> str:
    base = "Heurística de liquidez: suele convenir ejecutar entre 11:00–13:00 (Chile)."
    if learned and learned.get("ok"):
        return base + " " + learned.get("suggestion_text", "").strip()
    return base


