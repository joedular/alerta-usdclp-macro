def build_ml_dataset(daily: pd.DataFrame, macro_df: pd.DataFrame, horizon_days: int = 5) -> pd.DataFrame:
    df = daily.copy()

    df["usd_ret_1d"] = df["USDCLP"].pct_change(1)
    df["usd_ret_5d"] = df["USDCLP"].pct_change(5)
    df["usd_ma10"] = df["USDCLP"].rolling(10, min_periods=5).mean()
    df["usd_dev_ma10"] = (df["USDCLP"] / df["usd_ma10"]) - 1.0
    df["usd_vol_5d"] = df["usd_ret_1d"].rolling(5, min_periods=5).std()

    df["copper_ret_5d"] = macro_df["copper_ret_5d"]
    df["dxy_ret_5d"] = macro_df["dxy_ret_5d"]
    df["us10y_ret_5d"] = macro_df["us10y_ret_5d"]
    df["usd_pressure"] = macro_df["usd_pressure"]

    df["usd_future"] = df["USDCLP"].shift(-horizon_days)
    df["y_up_5d"] = (df["usd_future"] > df["USDCLP"]).astype(int)

    features = [
        "usd_ret_1d", "usd_ret_5d", "usd_dev_ma10",
        "copper_ret_5d", "dxy_ret_5d", "us10y_ret_5d",
        "usd_pressure", "usd_vol_5d"
    ]
    return df[features + ["y_up_5d"]].dropna()

def fit_predict_prob(daily: pd.DataFrame, macro_df: pd.DataFrame) -> Tuple[float, str]:
    dataset = build_ml_dataset(daily, macro_df, horizon_days=5)
    if len(dataset) < 180:
        return np.nan, f"ML: datos insuficientes ({len(dataset)} filas)."

    X = dataset.drop(columns=["y_up_5d"]).values
    y = dataset["y_up_5d"].values

    split = int(len(dataset) * 0.8)
    X_train, y_train = X[:split], y[:split]
    X_last = X[-1:].copy()

    model = Pipeline([
        ("scaler", StandardScaler()),
        ("clf", LogisticRegression(max_iter=2000, class_weight="balanced"))
    ])
    model.fit(X_train, y_train)

    prob_up = float(model.predict_proba(X_last)[0, 1])
    base_rate = float(y_train.mean())
    dbg = f"ML: prob_up_5d={prob_up:.2f} (base_rate_train={base_rate:.2f}, n_train={len(y_train)})"
    return prob_up, dbg


# =========================
# Traffic light + Score
# =========================
def traffic_light(action: str) -> str:
    if action == "COMPRAR":
        return green("🟢 COMPRAR")
    if action == "COMPRAR PARCIAL":
        return yellow("🟡 COMPRAR PARCIAL")
    return red("🔴 ESPERAR")

def compute_total_score(
    dev_ma10: float,
    intraday_ret: float,
    pressure: float,
    prob_up_5d: float,
    now_local: datetime,
    trend_label: str,
    season_best: Optional[int],
    season_conf: Optional[str],
) -> int:
    score = 55

    if np.isfinite(dev_ma10):
        score += int(np.clip((-dev_ma10) * 1800, -35, 35))
    if np.isfinite(intraday_ret):
        score -= int(np.clip(intraday_ret * 1200, 0, 12))
    if np.isfinite(pressure):
        score += int(np.clip(pressure * 4, -10, 10))

    if np.isfinite(prob_up_5d):
        score += int(np.clip((prob_up_5d - 0.5) * 60, -15, 15))

    if is_good_liquidity_time(now_local):
        score += 10
    elif is_market_ok_time(now_local):
        score += 5

    if trend_label == "BAJISTA":
        score += 5
    elif trend_label == "ALCISTA":
        score -= 5

    if season_best is not None and now_local.weekday() == season_best:
        bonus = 5 if season_conf in ("media", "alta") else 2
        score += bonus

    return int(np.clip(score, 0, 100))


# =========================
# CLI
# =========================
def parse_args():
    p = argparse.ArgumentParser(
        description="Alerta USD/CLP con macro + ML + semáforo + tendencia + estacionalidad (robusta a pocos meses)."
    )
    p.add_argument("--budget", type=float, default=300000)
    p.add_argument("--mode", choices=["clp", "usd"], default="clp")
    p.add_argument("--force", action="store_true")
    p.add_argument("--period", default="2y")

    p.add_argument("--season_months", type=int, default=6)
    p.add_argument("--season_min_rows", type=int, default=40)
    p.add_argument("--season_min_per_weekday", type=int, default=3)

    p.add_argument("--learn_hours", action="store_true",
                   help="Intentar sugerir ventana horaria desde intradía reciente (si hay datos).")

    # NUEVO
    p.add_argument("--max_stale_min", type=int, default=120,
                   help="Umbral para marcar intradía como STALE (minutos). Default 120.")
    p.add_argument("--no_daily_fallback", action="store_true",
                   help="Desactiva fallback a spot diario cuando el intradía está STALE (siempre usa intradía).")

    p.add_argument("--sound", action="store_true")
    p.add_argument("--voice", default="Jorge")
    return p.parse_args()


# =========================
# Main
# =========================
def main():
    args = parse_args()
    now = datetime.now(TZ)

    learned_hours = None
    if args.learn_hours:
        learned_hours = learn_best_hours_usdclp(now)

    # Daily base
    daily_series = {}
    for key, ticker in TICKERS.items():
        s = download_daily_close(ticker, period=args.period)
        s.name = key
        daily_series[key] = s
    daily = pd.concat(daily_series.values(), axis=1).dropna()

    trend = trend_summary(daily["USDCLP"])
    seas = seasonality_best_day(
        daily["USDCLP"],
        months=args.season_months,
        min_rows=args.season_min_rows,
        min_per_weekday=args.season_min_per_weekday,
    )
    ma10 = safe_item(daily["USDCLP"].rolling(10, min_periods=5).mean().iloc[-1])

    macro_df = compute_macro_components(daily)
    macro_last = macro_df.iloc[-1]
    pressure = safe_item(macro_last["usd_pressure"])

    # Intraday
    intra, intra_meta = fetch_intraday_usdclp()
    intra_ch = _to_tz_chile_index(intra)

    day_open, last_ts_ch = _compute_day_open_from_intraday(intra_ch)
    last_ts_ch = _ensure_tzaware_chile(last_ts_ch)

    age_min = (now - last_ts_ch).total_seconds() / 60.0
    stale = bool(np.isfinite(age_min) and age_min > float(args.max_stale_min))

    # Spot intradía (por defecto)
    spot_intraday = safe_item(intra_ch["Close"].iloc[-1]) if (intra_ch is not None and not intra_ch.empty) else float("nan")

    # Spot diario (close) por si hacemos fallback
    spot_daily = safe_item(daily["USDCLP"].iloc[-1])

    # Regla: fallback SOLO si:
    # - es intraday (no daily_fallback),
    # - está STALE,
    # - NO estás en --force,
    # - y NO pusiste --no_daily_fallback
    use_daily_spot = (
        intra_meta.get("source") == "intraday"
        and stale
        and (not args.force)
        and (not args.no_daily_fallback)
    )

    if use_daily_spot:
        spot_used = spot_daily
        spot_used_kind = "daily_close (fallback por STALE intradía)"
        day_open_used = float("nan")   # no inventamos apertura intradía si estamos usando daily
        intraday_ret = float("nan")
    else:
        spot_used = spot_intraday
        spot_used_kind = "intraday"
        day_open_used = day_open
        intraday_ret = (spot_used / day_open_used) - 1.0 if (np.isfinite(day_open_used) and day_open_used > 0) else float("nan")

    # Recomendación
    action0, rationale0, intraday_ret_core, dev_ma10 = recommend_core(spot_used, day_open_used, ma10, pressure)
    intraday_ret_use = intraday_ret if np.isfinite(intraday_ret) else intraday_ret_core

    action, rationale = apply_market_hours_gate(action0, rationale0, now, force=args.force, learned_hours=learned_hours)

    # ML
    prob_up_5d, ml_dbg = fit_predict_prob(daily, macro_df)

    if np.isfinite(prob_up_5d):
        if prob_up_5d >= PROB_HIGH and action == "ESPERAR":
            action = "COMPRAR PARCIAL"
            rationale += f" ML: prob. alta de subida 5d ({prob_up_5d:.2f}) → compra parcial en horario bueno."
        elif prob_up_5d <= PROB_LOW and action in ("COMPRAR", "COMPRAR PARCIAL"):
            action = "ESPERAR"
            rationale += f" ML: prob. baja de subida 5d ({prob_up_5d:.2f}) → esperar podría convenir."
        elif prob_up_5d <= PROB_LOW and action == "ESPERAR" and "ML:" not in rationale:
            rationale += f" ML: prob. baja de subida 5d ({prob_up_5d:.2f}) → refuerza esperar."

    if stale and intra_meta.get("source") == "intraday":
        rationale += f" Nota: intradía STALE ({age_min:.0f} min; umbral {args.max_stale_min})."
        if use_daily_spot:
            rationale += " Se usó spot diario (close) como referencia."
        else:
            rationale += " Se mantuvo spot intradía por FORCE/flag."

    season_best = seas.get("best_day") if seas.get("ok") else None
    season_conf = seas.get("confidence") if seas.get("ok") else None

    score = compute_total_score(
        dev_ma10, intraday_ret_use, pressure, prob_up_5d,
        now, trend.get("label", "n/a"), season_best, season_conf
    )

    light = traffic_light(action)
    buy_frac, buy_tip = suggest_buy_fraction(action)
    amount_str = estimate_amount(args.budget, args.mode, buy_frac, spot_used)
    hint = liquidity_hint(now)

    # Prints
    print(bold("=== ALERTA USD/CLP + MACRO + ML + TENDENCIA + ESTACIONALIDAD ==="))
    print(f"Fecha/hora Chile: {now.strftime('%Y-%m-%d %H:%M:%S')}")
    print()

    print(bold("Mercado USDCLP"))
    print(f"Fuente datos: {intra_meta['source']} | {intra_meta['ticker']} | {intra_meta['interval']} ({intra_meta['period']})")
    print(f"Último tick: {_fmt_dt(last_ts_ch)} (Chile)")
    tag = red(" (STALE)") if stale else ""
    print(f"Antigüedad dato: {age_min:.0f} min{tag}")
    print(f"Spot usado: {spot_used_kind}")
    print(f"Spot USDCLP: {spot_used:.2f}")

    if np.isfinite(day_open_used):
        print(f"Apertura día (según último tick): {day_open_used:.2f}")
        print(f"Retorno intradía (día del último tick): {intraday_ret_use*100:.2f}%")
    else:
        print("Apertura día: n/a (no disponible)")
        print("Retorno intradía: n/a (no disponible)")

    print(f"MA10 (diario): {ma10:.2f}")
    if np.isfinite(dev_ma10):
        print(f"Desvío vs MA10: {dev_ma10*100:.2f}%")
    else:
        print("Desvío vs MA10: n/a")
    print(hint)

    if args.learn_hours:
        if learned_hours and learned_hours.get("ok"):
            print(yellow("ℹ️ Horarios aprendidos: ") + learned_hours.get("suggestion_text", ""))
        else:
            reason = learned_hours.get("reason") if isinstance(learned_hours, dict) else "n/a"
            print(yellow("ℹ️ Horarios aprendidos: ") + f"n/a ({reason})")
    print()

    print(bold("Macro (últimos 5 días)"))
    print(f"DXY ret_5d:    {safe_item(macro_last['dxy_ret_5d'])*100:+.2f}%   z={safe_item(macro_last['dxy_z']):+.2f}")
    print(f"US10Y ret_5d:  {safe_item(macro_last['us10y_ret_5d'])*100:+.2f}%   z={safe_item(macro_last['us10y_z']):+.2f}")
    print(f"Cobre ret_5d:  {safe_item(macro_last['copper_ret_5d'])*100:+.2f}%   z={safe_item(macro_last['copper_z']):+.2f}")
    print(f"Pressure = DXYz + US10Yz - CobreZ = {pressure:+.2f}")
    print()

    print(bold("Tendencia (diario)"))
    print(f"Estado: {trend.get('label')}")
    if np.isfinite(trend.get("ma20", np.nan)):
        print(f"MA20={trend['ma20']:.2f}  MA50={trend['ma50']:.2f}  MA200={trend['ma200']:.2f}")
        print(f"Pendiente 30d: {trend['slope30']:+.3f} CLP/día  (~{trend['slope30_pct']:+.3f}%/día)")
        print(f"Retornos: 20d={trend['ret20']:+.2f}%  |  60d={trend['ret60']:+.2f}%")
    print()

    print(bold(f"Estacionalidad (últimos {args.season_months} meses, por día semana)"))
    if seas.get("ok"):
        tbl = seas["table"]
        method = seas.get("method", "n/a")
        conf = seas.get("confidence", "baja")
        rows_used = seas.get("rows_used", 0)
        too_sparse = seas.get("too_sparse", False)

        conf_txt = conf
        if conf == "alta":
