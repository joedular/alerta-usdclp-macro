        print(f"Método: {method} | Confianza: {conf_txt} | filas usadas: {rows_used}")
        if too_sparse:
            print(red("⚠️ Pocas muestras por día semana. Sugerencia: usa --season_months 4 a 9 para algo más estable."))

        for wd in range(7):
            med = float(tbl.loc[wd, "median"]) if pd.notna(tbl.loc[wd, "median"]) else np.nan
            mean = float(tbl.loc[wd, "mean"]) if pd.notna(tbl.loc[wd, "mean"]) else np.nan
            cnt = int(tbl.loc[wd, "count"])

            tag2 = ""
            if wd == seas["best_day"]:
                tag2 = green("  ← mejor")
