def recommend_core(spot: float, day_open: float, ma10: float, pressure: float) -> Tuple[str, str, float, float]:
    intraday_ret = (spot / day_open) - 1.0 if (np.isfinite(day_open) and day_open > 0) else float("nan")
    dev_ma10 = (spot / ma10) - 1.0 if (np.isfinite(ma10) and ma10 > 0) else float("nan")
    has_intraday = np.isfinite(intraday_ret)

    if has_intraday and intraday_ret >= THRESH_SPIKE_UP and np.isfinite(dev_ma10) and dev_ma10 > 0:
        action = "COMPRAR PARCIAL"
        rationale = (
            f"Subida intradía {intraday_ret*100:.2f}% y sobre MA10 ({dev_ma10*100:.2f}%). "
            "Evita comprar todo en el pico."
        )
    elif np.isfinite(dev_ma10) and dev_ma10 <= THRESH_CHEAP_VS_MA10:
        action = "COMPRAR"
        rationale = f"Está {dev_ma10*100:.2f}% bajo MA10 (barato relativo)."
    elif np.isfinite(dev_ma10) and dev_ma10 >= THRESH_EXPENSIVE_VS_MA10:
        action = "ESPERAR"
        rationale = f"Está {dev_ma10*100:.2f}% sobre MA10 (caro relativo)."
    else:
        action = "COMPRAR PARCIAL"
        rationale = (
            f"Cerca de MA10 ({dev_ma10*100:.2f}%). Compra en 2–3 partes."
            if np.isfinite(dev_ma10) else
            "Señal técnica parcial (datos incompletos). Compra en 2–3 partes."
        )

    if np.isfinite(pressure) and pressure >= PRESSURE_STRONG:
        rationale += f" Macro: presión USD alta (score {pressure:.2f}) → sesgo alcista."
        if action == "ESPERAR" and (not np.isfinite(dev_ma10) or dev_ma10 < (THRESH_EXPENSIVE_VS_MA10 + 0.01)):
            action = "COMPRAR PARCIAL"
            rationale += " Ajuste: compra parcial."
    elif np.isfinite(pressure) and pressure <= -PRESSURE_STRONG:
        rationale += f" Macro: presión USD baja (score {pressure:.2f}) → sesgo bajista."
        if action == "COMPRAR PARCIAL" and (not np.isfinite(dev_ma10) or abs(dev_ma10) < 0.01):
            action = "ESPERAR"
            rationale += " Ajuste: esperar."

    return action, rationale, intraday_ret, dev_ma10

def apply_market_hours_gate(
    action: str,
    rationale: str,
    now_local: datetime,
    force: bool,
    learned_hours: Optional[Dict[str, Any]],
) -> Tuple[str, str]:
    if force:
        return action, rationale + " (FORCE activado)."
    if not is_market_ok_time(now_local):
        msg = market_hours_gate_message(now_local, learned_hours)
        return "ESPERAR", rationale + f" Además estás fuera de horario; {msg}"
    return action, rationale

def suggest_buy_fraction(action: str) -> Tuple[float, str]:
    if action == "COMPRAR":
        return 1.0, "Compra 100% hoy (o 70/30 si quieres suavizar)."
    if action == "COMPRAR PARCIAL":
        return 0.4, "Compra 30%–50% hoy y el resto en 7–14 días o en la próxima caída."
    return 0.0, "Espera 2–7 días y vuelve a correr el script."

def estimate_amount(budget: float, mode: str, frac: float, spot_usdclp: float) -> str:
    if frac <= 0:
        return "Monto recomendado hoy: $0 (esperar)."
    if mode == "clp":
        clp = int(round((budget * frac) / 1000.0) * 1000)
        est_usd = (clp / spot_usdclp) if spot_usdclp > 0 else 0.0
        return f"Monto recomendado hoy: ${clp:,} CLP (≈ {est_usd:.0f} USD)."
    usd = round(budget * frac, 2)
    est_clp = int(round((usd * spot_usdclp) / 1000.0) * 1000)
    return f"Monto recomendado hoy: {usd:.2f} USD (≈ ${est_clp:,} CLP)."


