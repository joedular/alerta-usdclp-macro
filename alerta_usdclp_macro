def trend_summary(usd_daily: pd.Series) -> Dict[str, Any]:
    s = usd_daily.dropna()
    if len(s) < 220:
        return {
            "label": "n/a (datos insuficientes)",
            "ma20": np.nan, "ma50": np.nan, "ma200": np.nan,
            "slope30": np.nan, "slope30_pct": np.nan,
            "ret20": np.nan, "ret60": np.nan,
        }

    ma20 = safe_item(s.rolling(20).mean().iloc[-1])
    ma50 = safe_item(s.rolling(50).mean().iloc[-1])
    ma200 = safe_item(s.rolling(200).mean().iloc[-1])

    last = s.tail(30)
    x = np.arange(len(last))
    y = last.values
    slope = np.polyfit(x, y, 1)[0]
    slope_pct = (slope / safe_item(s.iloc[-1])) * 100.0

    ret20 = safe_item(s.pct_change(20).iloc[-1]) * 100.0
    ret60 = safe_item(s.pct_change(60).iloc[-1]) * 100.0

    if ma20 > ma50 > ma200 and slope > 0:
        label = "ALCISTA"
    elif ma20 < ma50 < ma200 and slope < 0:
        label = "BAJISTA"
    else:
        label = "LATERAL / MIXTA"

    return {
        "label": label,
        "ma20": ma20, "ma50": ma50, "ma200": ma200,
        "slope30": slope, "slope30_pct": slope_pct,
        "ret20": ret20, "ret60": ret60,
    }

def _confidence_label(total_rows: int, min_per_wd: int, counts_by_wd: pd.Series) -> str:
    min_cnt = int(counts_by_wd.min()) if len(counts_by_wd) else 0
    if total_rows >= 120 and min_cnt >= max(8, min_per_wd):
        return "alta"
    if total_rows >= 70 and min_cnt >= max(5, min_per_wd):
        return "media"
    return "baja"

def seasonality_best_day(
    usd_daily: pd.Series,
    months: int = 6,
    min_rows: int = 40,
    min_per_weekday: int = 3,
) -> Dict[str, Any]:
    s = usd_daily.dropna()
    if s.empty:
        return {"ok": False, "reason": "serie vacía"}

    cutoff = s.index.max() - pd.DateOffset(months=months)
    s2 = s[s.index >= cutoff]

    method = "raw_level"
    resid = None

    if len(s2) >= 55:
        ma50 = s2.rolling(50, min_periods=25).mean()
        r = (s2 / ma50) - 1.0
        r = r.dropna()
        if len(r) >= min_rows:
            resid = r
            method = "detrend_ma50"

    if resid is None and len(s2) >= 28:
        ma20 = s2.rolling(20, min_periods=10).mean()
        r = (s2 / ma20) - 1.0
        r = r.dropna()
        if len(r) >= max(25, min_rows // 2):
            resid = r
            method = "detrend_ma20"

    if resid is None:
        resid = s2.copy()
        method = "raw_level"

    df = pd.DataFrame({"x": resid})
    df["weekday"] = df.index.weekday

    by = df.groupby("weekday")["x"].agg(["median", "mean", "count"]).sort_index()
    for wd in range(7):
        if wd not in by.index:
            by.loc[wd] = [np.nan, np.nan, 0]
    by = by.sort_index()

    counts = by["count"].astype(int)
    conf = _confidence_label(len(df), min_per_weekday, counts[counts > 0])
    too_sparse = (counts[counts > 0].min() if (counts > 0).any() else 0) < min_per_weekday

    med_series = by["median"].replace([np.inf, -np.inf], np.nan).dropna()
    if med_series.empty:
        return {"ok": False, "reason": "no se pudo calcular estacionalidad (NaN)", "method": method}

    best_idx = int(med_series.idxmin())
    worst_idx = int(med_series.idxmax())

    return {
        "ok": True,
        "months": months,
        "method": method,
        "confidence": conf,
        "too_sparse": bool(too_sparse),
        "min_per_weekday": min_per_weekday,
        "rows_used": int(len(df)),
        "table": by,
        "best_day": best_idx,
        "worst_day": worst_idx,
        "best_day_name": WEEKDAY_NAMES[best_idx],
        "worst_day_name": WEEKDAY_NAMES[worst_idx],
        "best_median": float(by.loc[best_idx, "median"]),
        "worst_median": float(by.loc[worst_idx, "median"]),
    }


